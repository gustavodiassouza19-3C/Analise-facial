DEBUG=true
DATABASE_URL=sqlite+aiosqlite:///./facial_analysis.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/facial_analysis
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Database pool (production)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# Rate limiting
RATE_LIMIT_AUTH=5/minute
RATE_LIMIT_ANALYSIS=10/hour
RATE_LIMIT_GENERAL=60/minute

# OpenRouter AI
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_MODEL=google/gemma-4-26b-a4b-it:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TIMEOUT=30
OPENROUTER_REFERER=https://facemax.app

# Request limits
MAX_IMAGE_BASE64_SIZE_MB=10
